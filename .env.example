# База данных
DATABASE_URL="postgresql://user:password@localhost:5432/igrulya?schema=public"

# ЮKassa
YOOKASSA_SHOP_ID="123456"
YOOKASSA_SECRET_KEY="test_..."
YOOKASSA_RETURN_URL="https://puppyigrulya.ru/checkout/success"

# СДЭК (доставка: калькулятор тарифов, виджет ПВЗ)
CDEK_ACCOUNT="..."
CDEK_SECURE_PASSWORD="..."
CDEK_API_URL="https://api.cdek.ru/v2"
# Город отправления для виджета (название)
NEXT_PUBLIC_CDEK_FROM_CITY="Москва"
# Ключ Яндекс.Карт (обязателен для виджета ПВЗ): developer.tech.yandex.ru
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""
# Секрет для webhook СДЭК — передаётся в URL (?secret=...). Добавить в URL подписки.
CDEK_WEBHOOK_SECRET="random-secret-string"

# СДЭК Фулфилмент (создание заказов FBS со склада)
CDEK_FF_ACCOUNT="..."
CDEK_FF_SECURE_PASSWORD="..."
CDEK_FF_API_BASE="https://..."
CDEK_FF_WAREHOUSE_CITY_CODE="44"
# Числовой ID склада в ЛК СДЭК Fulfillment (OrderAdmin) — например, 21718.
# Видно в ЛК на странице склада в URL или строке "IM-MSK226-8688 MSK2290 (21718)".
# ВНИМАНИЕ: это НЕ код города СДЭК для тарифов — это разные числа.
CDEK_FF_WAREHOUSE_ID="21718"
# Числовой код города отправления (CDEK city code) для серверной верификации стоимости доставки
# Можно узнать через /v2/location/cities?city=Москва. Обычно совпадает с CDEK_FF_WAREHOUSE_CITY_CODE.
CDEK_FROM_CITY_CODE="44"

# Telegram
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
TELEGRAM_CHAT_ID="123456789"

# JWT
JWT_SECRET="random-long-secret-string"

# Подпись ссылки на страницу «Заказ оформлен» (опционально; иначе используется JWT_SECRET)
# SUCCESS_ORDER_SECRET="another-secret-for-success-page"

# App
NEXT_PUBLIC_APP_URL="https://puppyigrulya.ru"

# Playwright E2E (опционально; по умолчанию admin / admin123 после prisma seed)
# E2E_ADMIN_LOGIN="admin"
